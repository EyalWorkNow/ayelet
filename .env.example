# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=petfinder-c8561
FIREBASE_DATABASE_ID=ai-studio-7fde779f-dfb3-4269-a331-c38f4e595886
# Paste service account JSON as one-line string (Firebase Console → Project Settings → Service Accounts)
FIREBASE_SERVICE_ACCOUNT=
# OR provide path to the downloaded JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=

# ─── WhatsApp — Green API (recommended for Israel) ───────────────────────────
# Sign up at https://green-api.com → create instance
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# ─── WhatsApp — Twilio (alternative) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ─── Studio ───────────────────────────────────────────────────────────────────
OWNER_PHONE=972526201389
STUDIO_NAME=Ayelet Netanel Studio
